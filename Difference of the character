import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String str = sc.next();
        int count = 0;
        int count2 = 0;
        int diff =0 ;
        for(int i=0;i<str.length();i++){
            char ch = str.charAt(i);
            if(ch =='*'){
                count++;
            }
            else {
                count2++;
            }
        }
             if(count > count2){
                diff = count-count2;
                if(diff%2!=0){
                System.out.println("The Difference of the character in the given string: 00"+diff);
            }
            else{
                System.out.println("The Difference of the character in the given string: 0"+diff);
            }
             }
            else if(count<count2){
                diff = count2-count;
                if(diff%2==0){
                System.out.println("The Difference of the character in the given string: 00"+diff);
            }
            else{
                System.out.println("The Difference of the character in the given string: 0"+diff);
            }
            }
            else{
                System.out.println("0" );
            }
    }
}
