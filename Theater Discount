import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int tickets = sc.nextInt();
        char refreshment = sc.next().charAt(0);
        char coupon = sc.next().charAt(0);
        char ticketType = sc.next().charAt(0);

        if (tickets < 5 || tickets > 40) {
            System.out.println("Minimum of 5 and Maximum of 40 tickets");
            return;
        }

        if (ticketType != 'k' && ticketType != 'q') {
            System.out.println("Invalid Input");
            return;
        }

        double ticketCost;

        if (ticketType == 'k') {
            ticketCost = tickets * 75;
        } else {
            ticketCost = tickets * 150;
        }

        if (refreshment == 'y') {
            ticketCost += tickets * 50;
        }

        if (tickets > 20) {
            ticketCost -= ticketCost * 0.10; // 10% discount
        }

        if (coupon == 'y') {
            ticketCost -= ticketCost * 0.02; // 2% discount
        }

        System.out.printf("Ticket cost:%.2f", ticketCost);
    }
}
